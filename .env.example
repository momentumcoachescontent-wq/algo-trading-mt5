# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://fxttpblmiqgoerbvfons.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── Cloudflare Worker ─────────────────────────────────────────────────────
